# Environment Variables for Local GitHub Actions Testing
# These are non-sensitive configuration values

# Project Configuration
PROJECT_ID=nosilha-test
REGION=us-east1

# Build Configuration
NODE_ENV=test
RAILS_ENV=test
SPRING_PROFILES_ACTIVE=test

# Database Configuration (for local testing)
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/nosilha_test
SPRING_DATASOURCE_USERNAME=test
SPRING_DATASOURCE_PASSWORD=test
DATABASE_URL=jdbc:postgresql://postgres:5432/nosilha_test
DATABASE_USERNAME=test
DATABASE_PASSWORD=test

# Local Service URLs
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
FIRESTORE_EMULATOR_HOST=firestore:8080
GCS_EMULATOR_HOST=gcs:4443

# Act-specific Configuration
ACT_TESTING=true
CI=true
RUNNER_OS=Linux
RUNNER_ARCH=X64

# GitHub Context Simulation
GITHUB_REPOSITORY=jcosta/nos-ilha
GITHUB_WORKSPACE=/github/workspace
GITHUB_ACTOR=act-user