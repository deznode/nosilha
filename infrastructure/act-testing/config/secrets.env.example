# GitHub Actions Secrets Template for Local Testing
# Copy this file to secrets.env and fill in your actual values
# NEVER commit secrets.env to version control!

# GitHub Token (for API access)
GITHUB_TOKEN=ghp_your_github_token_here

# Google Cloud Platform
GCP_SA_KEY={"type":"service_account","project_id":"your-project"}
GCP_PROJECT_ID=your-gcp-project-id

# Production URLs (for integration testing)
PRODUCTION_API_URL=https://your-production-api-url
NEXT_PUBLIC_API_URL=https://your-api-url

# Mapbox Configuration
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=pk.your_mapbox_token_here

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-supabase-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Optional: Custom registry credentials
DOCKER_REGISTRY_USER=your_registry_user
DOCKER_REGISTRY_TOKEN=your_registry_token