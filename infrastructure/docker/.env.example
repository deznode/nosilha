# Environment variables for Docker Compose services
# Copy this file to .env and fill in your actual values

# Frontend API Configuration
# Use host.docker.internal for build-time API access (macOS/Windows)
# Use backend service name for runtime API access in Docker Compose
NEXT_PUBLIC_API_URL=http://localhost:8080

# Mapbox Configuration
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=your_mapbox_token_here

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Backend Configuration
# Copy from backend/.env.local or use the default local development secret
SUPABASE_JWT_SECRET=AwKv4vTWS+oLz+xHvyMwyDwbTE5CBrR1CulEzU1JEW+wS2ZVvoNZsQMQOsHASZggH2XBF0YA8ZzApfhRE1Z5AA==

# Analytics (Optional)
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_CLARITY_PROJECT_ID=
