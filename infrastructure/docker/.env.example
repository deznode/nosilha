# Environment variables for Docker Compose services
# Copy this file to .env and fill in your actual values

# Frontend API Configuration
# Use host.docker.internal for build-time API access (macOS/Windows)
# Use backend service name for runtime API access in Docker Compose
NEXT_PUBLIC_API_URL=http://localhost:8080

# Mapbox Configuration
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=your_mapbox_token_here

# Supabase Configuration
# Use the publishable key (sb_publishable_...) from your Supabase project settings
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_your_key_here

# Backend Configuration
# Supabase project URL for JWKS-based JWT verification (no secret needed)
SUPABASE_PROJECT_URL=https://your-project.supabase.co

# Analytics (Optional)
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_CLARITY_PROJECT_ID=

# ISR Cache Revalidation (shared secret between frontend and backend)
# Used to invalidate frontend cache when admin makes content changes
# Generate with: openssl rand -base64 32
REVALIDATE_SECRET=
FRONTEND_URL=http://localhost:3000

# AI Image Analysis (Backend)
# Google Gemini for cultural context, alt text, and descriptions
# Get API key from: https://aistudio.google.com/apikey
AI_ENABLED=true
AI_GEMINI_ENABLED=true
AI_GEMINI_API_KEY=your_gemini_api_key
SPRING_AI_MODEL_CHAT=google-genai

# Cloudflare R2 Configuration (for media uploads)
R2_ACCOUNT_ID=your_r2_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=nosilha-media
R2_PUBLIC_URL=https://media.nosilha.com
R2_ENABLED=false
