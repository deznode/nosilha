# terraform.tfvars.example
#
# Rename this file to 'terraform.tfvars' and fill in your GCP Project ID.
# Do not commit the actual terraform.tfvars file to version control.

# Required variables
gcp_project_id = "your-gcp-project-id-goes-here"
gcp_region     = "us-east1"

# Optional: For cost monitoring
billing_account_id = ""
budget_notification_channels = ["your-notification-channel-id"]

# Cloudflare (DNS, R2 storage)
cloudflare_api_token  = "your-cloudflare-api-token"
cloudflare_account_id = "your-cloudflare-account-id"
cloudflare_zone_id    = "your-cloudflare-zone-id"

