#!/bin/bash
# =============================================================================
# Pre-commit Hook - Secret Detection
# Prevents commits containing secrets using Gitleaks
# =============================================================================
#
# Installation:
#   cp scripts/hooks/pre-commit .git/hooks/pre-commit
#   chmod +x .git/hooks/pre-commit
#
# This hook uses 'gitleaks protect --staged' which only scans staged changes,
# making it fast enough for interactive use.
#
# =============================================================================

# Check if gitleaks is installed
if ! command -v gitleaks &> /dev/null; then
    echo "Warning: gitleaks is not installed. Skipping secret scan."
    echo "Install with: brew install gitleaks"
    exit 0
fi

echo "Running gitleaks on staged changes..."

# Run gitleaks on staged changes only (fast)
if ! gitleaks protect --staged --verbose; then
    echo ""
    echo "=================================="
    echo "COMMIT BLOCKED: Secrets detected!"
    echo "=================================="
    echo ""
    echo "Please remove the secrets before committing."
    echo "If this is a false positive, add it to .gitleaksignore"
    echo ""
    echo "Format for .gitleaksignore:"
    echo "  <commit-hash>:<file>:<rule-id>:<line-number>"
    echo ""
    exit 1
fi

echo "No secrets detected. Proceeding with commit."
exit 0
