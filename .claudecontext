# Claude Context Configuration for Nos Ilha
# This file provides additional context hints for Claude Code

project_type: "full_stack_web_application"
domain: "cultural_heritage"
location: "brava_island_cape_verde"

# Primary Technologies
languages:
  - "typescript"
  - "kotlin" 
  - "sql"
  - "hcl"

frameworks:
  - "nextjs_15_app_router"
  - "spring_boot_3_4_7"
  - "tailwind_css"
  - "catalyst_ui"

cloud_platform: "google_cloud_platform"
database: "postgresql_with_firestore"
auth: "supabase_jwt"

# Backend Module Structure (Spring Modulith)
backend_modules:
  - "shared"     # Common domain, API contracts, events, exceptions
  - "auth"       # Authentication and JWT validation
  - "directory"  # Directory entries (STI: Restaurant, Hotel, Landmark, Beach)
  - "media"      # Media management and AI processing

# Key Architectural Patterns
patterns:
  - "single_table_inheritance"
  - "domain_driven_design"
  - "spring_modulith_architecture"
  - "event_driven_communication"
  - "mobile_first_responsive"
  - "dark_mode_support"
  - "incremental_static_regeneration"
  - "server_components_first"
  - "module_boundary_verification"

# Development Approach
development_style:
  - "component_composition"
  - "type_safety_first"
  - "accessibility_focused"
  - "performance_optimized"
  - "security_by_design"

# Brand Colors (for UI context)
brand_colors:
  primary: "#005A8D"  # Ocean Blue
  secondary: "#3E7D5A"  # Valley Green
  accent: "#D90368"  # Bougainvillea Pink
  warning: "#F7B801"  # Sunny Yellow

# Key Documentation Files
documentation:
  architecture:
    - "docs/ARCHITECTURE.md"           # System architecture and component flow
    - "docs/SPRING_MODULITH.md"        # Backend module architecture and events
    - "docs/API_CODING_STANDARDS.md"   # Backend coding standards and patterns
  frontend:
    - "docs/DESIGN_SYSTEM.md"          # UI/UX design system and components
    - "docs/STATE_MANAGEMENT.md"       # State management patterns (Zustand, TanStack Query)
    - "docs/TESTING.md"                # Testing guide (Playwright, Vitest, Storybook)
  deployment:
    - "docs/CI_CD_PIPELINE.md"         # CI/CD workflows and deployment
    - "docs/SECRET_MANAGEMENT.md"      # Secret management and security

# Common File Patterns
file_conventions:
  components: "kebab-case.tsx"
  pages: "page.tsx"
  layouts: "layout.tsx"
  api_routes: "/api/v1/*"
  styles: "globals.css + tailwind"
  kotlin_modules: "PackageInfo.kt (@PackageInfo annotation for Spring Modulith)"
  event_listeners: "@ApplicationModuleListener for inter-module communication"

# MCP Server Configuration
mcp_servers:
  playwright:
    purpose: "Browser automation and visual testing"
    config: "frontend/.mcp/server-config.json"
    documentation: "frontend/README-MCP.md"
    capabilities:
      - "Automated browser interaction and testing"
      - "Visual testing and screenshot generation"
      - "Accessibility compliance validation (WCAG 2.1 AA)"
      - "Performance testing and Core Web Vitals monitoring"
  sequential_thinking:
    purpose: "Deep reasoning for complex problem-solving"
    capabilities:
      - "Multi-step analytical thinking"
      - "Hypothesis generation and verification"
      - "Dynamic problem-solving with backtracking"

# Specification System (Speckit)
speckit:
  system: "Speckit feature specification workflow"
  specs_directory: "plan/specs/"
  spec_structure:
    - "NNN-feature-name/spec.md"     # Feature specification document
    - "NNN-feature-name/plan.md"     # Implementation plan (optional)
    - "NNN-feature-name/tasks.md"    # Task breakdown (optional)

  workflow_phases:
    - "Specify: Create spec.md from user description"
    - "Clarify: Resolve ambiguities and requirements"
    - "Plan: Generate implementation plan.md"
    - "Tasks: Break down into actionable tasks.md"
    - "Implement: Execute tasks on feature branch"
    - "Review: Quality checks and PR creation"

  spec_components:
    - "User Scenarios & Testing (mandatory)"
    - "Functional Requirements (FR-NNN)"
    - "Key Entities (conceptual)"
    - "Success Metrics"
    - "Dependencies & Assumptions"
    - "Risk Assessment"
    - "Review & Acceptance Checklist"

  speckit_usage:
    - "Focus on WHAT users need and WHY (not HOW)"
    - "Written for business stakeholders, not developers"
    - "No implementation details (tech stack, APIs, code)"
    - "Requirements must be testable and unambiguous"
    - "Resolve all [NEEDS CLARIFICATION] before planning"

# CI/CD Configuration
ci_cd:
  authentication: "OIDC Workload Identity Provider (no service account keys)"
  workload_identity: "projects/936816281178/locations/global/workloadIdentityPools/github-actions-pool/providers/github-provider"
  service_account: "nosilha-cicd-deployer@nosilha.iam.gserviceaccount.com"
  workflows:
    core:
      - "backend-ci.yml"        # Spring Boot CI/CD with Spring Modulith verification
      - "frontend-ci.yml"       # Next.js CI/CD with bundle analysis
      - "infrastructure-ci.yml" # Terraform infrastructure management
      - "pr-validation.yml"     # Consolidated PR validation
      - "integration-ci.yml"    # Cross-service integration tests
    specialized:
      - "cost-monitoring.yml"       # GCP cost tracking and alerts
      - "performance-analytics.yml" # Performance monitoring
      - "storybook-deploy.yml"      # Component library deployment
  registry: "us-east1-docker.pkg.dev"
  region: "us-east1"

# Testing Patterns
testing:
  backend:
    - "JUnit tests with PostgreSQL integration"
    - "Spring Modulith module boundary verification tests"
    - "Coverage threshold enforcement (70% minimum)"
    - "Jacoco coverage reporting"
    - "PlantUML diagram generation for module visualization"
  frontend:
    - "Playwright E2E tests with MCP server"
    - "Vitest unit tests for components and utilities"
    - "Storybook component documentation and testing"
    - "Visual regression testing with screenshots"
    - "Accessibility testing (WCAG 2.1 AA compliance)"
  integration:
    - "Cross-service API integration tests"
    - "Security header validation"
    - "Performance and Core Web Vitals monitoring"
    - "Health check verification"