# =============================================================================
# Local Development Environment Variables
# Copy to .env.local and fill in actual values
# Loaded by bootRun task in build.gradle.kts
# =============================================================================

# Cloudflare R2 Configuration (media uploads)
R2_ACCOUNT_ID=your_r2_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=nosilha-media
R2_PUBLIC_URL=https://media.nosilha.com
R2_ENABLED=false

# AI Image Analysis — Master switch
AI_ENABLED=true

# Google Gemini (cultural context, alt text, descriptions)
# Get API key from: https://aistudio.google.com/apikey
AI_GEMINI_ENABLED=true
AI_GEMINI_API_KEY=your_gemini_api_key

# Spring AI auto-configuration: google-genai to enable, none to disable
SPRING_AI_MODEL_CHAT=google-genai

# Google Cloud Vision (labels, OCR, landmarks)
# Auth: run `gcloud auth application-default login` or set GOOGLE_APPLICATION_CREDENTIALS
# Enable API: gcloud services enable vision.googleapis.com
AI_CLOUD_VISION_ENABLED=false
