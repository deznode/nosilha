# ===================================================================
# LOCAL DEVELOPMENT CONFIGURATION EXAMPLE
# Copy this file to application-local.yml and fill in your values
# ===================================================================

app:
  cors:
    # Comma-separated list of allowed origins for CORS
    allowed-origins: http://localhost:3000,https://localhost:3000

spring:
  # Multipart file upload configuration
  servlet:
    multipart:
      max-file-size: 10MB        # Allow up to 10MB per file
      max-request-size: 15MB     # Allow up to 15MB per request

  # Database Configuration for Local Development
  # Uses local PostgreSQL via Docker Compose
  datasource:
    url: jdbc:postgresql://localhost:5432/nosilha_db
    password: nosilha
    username: nosilha
    hikari:
      maximum-pool-size: 5
      minimum-idle: 2
      leak-detection-threshold: 60000

  # JPA/Hibernate Configuration
  jpa:
    hibernate:
      ddl-auto: validate
    show-sql: false
    properties:
      hibernate:
        format_sql: false
        jdbc:
          batch_size: 20

  # OAuth2 Resource Server Configuration (JWKS-based JWT verification)
  security:
    oauth2:
      resourceserver:
        jwt:
          jwk-set-uri: ${supabase.project-url}/auth/v1/.well-known/jwks.json
          issuer-uri: ${supabase.project-url}/auth/v1

# Supabase Configuration
# Uses public JWKS endpoint for JWT verification (no secret needed)
supabase:
  project-url: https://your-project.supabase.co

# Management endpoints for health checks and debugging
management:
  endpoints:
    web:
      exposure:
        include: health,info,metrics
  endpoint:
    health:
      show-details: always

# Logging configuration for debugging
logging:
  level:
    com:
      nosilha: DEBUG
      google:
        cloud: debug
    org.springframework.security: DEBUG
    root: INFO

# Swagger/OpenAPI documentation (enabled for local development)
springdoc:
  swagger-ui:
    path: /swagger-ui.html
    enabled: true
  api-docs:
    enabled: true