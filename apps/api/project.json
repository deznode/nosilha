{
  "name": "api",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/api/src",
  "projectType": "application",
  "tags": ["type:app", "scope:api"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "./gradlew build",
        "cwd": "apps/api"
      },
      "cache": true,
      "inputs": [
        "{projectRoot}/src/**/*",
        "{projectRoot}/build.gradle.kts",
        "{projectRoot}/settings.gradle.kts",
        "{projectRoot}/gradle.properties"
      ],
      "outputs": ["{projectRoot}/build"]
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "./gradlew test",
        "cwd": "apps/api"
      },
      "cache": true,
      "inputs": [
        "{projectRoot}/src/**/*",
        "{projectRoot}/build.gradle.kts"
      ],
      "outputs": ["{projectRoot}/build/test-results", "{projectRoot}/build/reports"]
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "./gradlew bootRun --args='--spring.profiles.active=local'",
        "cwd": "apps/api"
      }
    },
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "./gradlew bootRun --args='--spring.profiles.active=local'",
        "cwd": "apps/api"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "./gradlew ktlintCheck",
        "cwd": "apps/api"
      },
      "cache": true,
      "inputs": ["{projectRoot}/src/**/*.kt"],
      "outputs": ["{projectRoot}/build/reports/ktlint"]
    }
  }
}
