# Nos Ilha Frontend Environment Variables
# Copy this file to .env.local and fill in your values

# Next.js Configuration
NEXT_PUBLIC_API_URL=http://localhost:8080
# NEXT_PUBLIC_API_URL=https://api.nosilha.com

# API Configuration
# Controls which API implementation to use:
# - 'true': Uses mock API with static data (ideal for frontend development, testing, or when backend is unavailable)
# - 'false': Uses real backend API (for integration testing and production)
#
# To switch APIs:
# 1. Change this value in your .env.local file
# 2. Restart your development server (npm run dev)
# 3. The change will be logged in the browser console
NEXT_PUBLIC_USE_MOCK_API=false

# Mapbox Integration
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=your_mapbox_token_here

# Supabase Authentication
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
# Supabase Stub Client (Development only)
# Set to 'true' to use stub client when Supabase credentials are unavailable
# NEXT_PUBLIC_SUPABASE_USE_STUB=false

# Analytics Integration (optional for local development)
# Google Analytics 4 - Get from https://analytics.google.com
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
# Microsoft Clarity - Get from https://clarity.microsoft.com
NEXT_PUBLIC_CLARITY_PROJECT_ID=abcd1234

# SEO - Google Site Verification (optional)
# GOOGLE_SITE_VERIFICATION=your_verification_code

# Playwright Testing (E2E tests - local development only)
PLAYWRIGHT_BASE_URL=http://localhost:3000

# Debug and Development
NODE_ENV=development

# Resend Email Service (Newsletter Subscription)
# Get your API key from: https://resend.com/api-keys
# Note: RESEND_SEGMENT_ID is only needed if you plan to use the Broadcasts API to send newsletters
#       For just collecting newsletter subscribers, only RESEND_API_KEY is required
RESEND_API_KEY=your_resend_api_key_here

# GitHub Integration (Story Archival)
# Used by the archive-story server action to commit MDX files to the repository
# Get your Personal Access Token from: https://github.com/settings/tokens
# Required scopes: repo (full control of private repositories)
GITHUB_TOKEN=your_github_personal_access_token
GITHUB_REPO_OWNER=deznode
GITHUB_REPO_NAME=nosilha
GITHUB_CONTENT_BRANCH=content
