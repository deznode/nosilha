{
  "browser": {
    "browserName": "chromium",
    "headless": true,
    "launchOptions": {
      "channel": "chrome"
    },
    "contextOptions": {
      "viewport": { "width": 1280, "height": 720 },
      "ignoreHTTPSErrors": true
    }
  },
  "capabilities": ["tabs", "vision", "pdf"],
  "outputDir": "./playwright-mcp-output"
}
