# =============================================================================
# pnpm Configuration for Nos Ilha Frontend
# Next.js 15 + React 19 + Turbopack + TypeScript 5.x
# =============================================================================

# -----------------------------------------------------------------------------
# Turbopack Compatibility
# -----------------------------------------------------------------------------
# Research: Next.js 15 requires hoisting of framework packages
# Source: GitHub Issue #74731, pnpm docs 2025
public-hoist-pattern[]=next
public-hoist-pattern[]=@next/*
public-hoist-pattern[]=react
public-hoist-pattern[]=react-dom

# Optional: Uncomment if Mapbox GL JS has issues
# public-hoist-pattern[]=mapbox-gl

# Optional: ESLint plugins (uncomment if needed)
# public-hoist-pattern[]=*eslint-plugin-*

# -----------------------------------------------------------------------------
# Peer Dependencies
# -----------------------------------------------------------------------------
# Research: Prevents CI failures on peer dependency mismatches
# Recommended for solo-maintained projects
strict-peer-dependencies=false
auto-install-peers=true

# -----------------------------------------------------------------------------
# Store Configuration
# -----------------------------------------------------------------------------
# Uses local .pnpm-store for project isolation
store-dir=.pnpm-store

# -----------------------------------------------------------------------------
# Lockfile Settings
# -----------------------------------------------------------------------------
lockfile=true

# -----------------------------------------------------------------------------
# Performance Optimizations
# -----------------------------------------------------------------------------
# Cache side-effects for faster reinstalls
side-effects-cache=true

# Prefer offline mode when possible (speeds up reinstalls)
# prefer-offline=true

# -----------------------------------------------------------------------------
# Security (Optional)
# -----------------------------------------------------------------------------
# Enforce pnpm usage (uncomment after migration)
# engine-strict=true
