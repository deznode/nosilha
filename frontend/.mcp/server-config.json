{
  "browser": {
    "browserName": "chromium",
    "headless": false,
    "launchOptions": {
      "channel": "chrome",
      "args": [
        "--no-sandbox",
        "--disable-web-security",
        "--allow-running-insecure-content"
      ]
    },
    "contextOptions": {
      "viewport": { 
        "width": 1280, 
        "height": 720 
      },
      "ignoreHTTPSErrors": true,
      "acceptDownloads": true,
      "permissions": ["camera", "microphone", "geolocation"]
    }
  },
  "server": {
    "port": 8931,
    "host": "localhost"
  },
  "capabilities": [
    "tabs",
    "vision", 
    "pdf"
  ],
  "outputDir": "./playwright-mcp-output",
  "network": {
    "allowedOrigins": [
      "http://localhost:3000",
      "http://localhost:8080", 
      "https://*.vercel.app",
      "https://*.nosilha.com",
      "https://run.app"
    ]
  },
  "imageResponses": "allow"
}