{
  "mcpServers": {
    "playwright": {
      "command": "npx",
      "args": [
        "@playwright/mcp@latest", 
        "--config", 
        ".mcp/server-config.json"
      ],
      "env": {
        "NODE_ENV": "development"
      }
    },
    "playwright-headless": {
      "command": "npx", 
      "args": [
        "@playwright/mcp@latest",
        "--config",
        ".mcp/server-config.json", 
        "--headless"
      ],
      "env": {
        "NODE_ENV": "production"
      }
    },
    "playwright-port": {
      "url": "http://localhost:8931/mcp"
    }
  }
}