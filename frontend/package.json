{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "test:performance": "playwright test --project=performance",
    "test:mobile": "playwright test --project=mobile-chrome --project=mobile-safari",
    "test:api": "playwright test --project=api-contracts",
    "test:critical": "playwright test tests/shared/",
    "test:unit": "vitest --project unit",
    "lighthouse:audit": "lhci autorun",
    "lighthouse:upload": "lhci upload",
    "lighthouse:assert": "lhci assert",
    "k6:directory": "k6 run tests/k6/directory-api-load.js",
    "k6:towns": "k6 run tests/k6/towns-api-load.js",
    "k6:journey": "k6 run tests/k6/integrated-user-journey.js",
    "k6:all": "npm run k6:directory && npm run k6:towns && npm run k6:journey",
    "test:setup": "node tests/setup/pre-test-setup.js",
    "test:teardown": "node tests/setup/post-test-cleanup.js",
    "test:ci": "npm run test:setup && npm run test:e2e && npm run lighthouse:audit && npm run test:teardown",
    "test:ci:mobile": "npm run test:mobile && npm run lighthouse:audit",
    "test:ci:performance": "npm run test:performance && npm run k6:all",
    "test:ci:contracts": "npm run test:api",
    "mcp:server": "npx @playwright/mcp@latest --config .mcp/server-config.json",
    "mcp:server:headless": "npx @playwright/mcp@latest --config .mcp/server-config.json --headless",
    "mcp:server:port": "npx @playwright/mcp@latest --config .mcp/server-config.json --port 8931",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint:fix": "next lint --fix && prettier --write .",
    "lint:all": "next lint && prettier --check .",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.4",
    "@heroicons/react": "^2.2.0",
    "@hookform/resolvers": "^5.2.2",
    "@supabase/supabase-js": "^2.50.0",
    "@tanstack/react-query": "^5.90.3",
    "@tanstack/react-query-devtools": "^5.90.2",
    "clsx": "^2.1.1",
    "framer-motion": "^12.18.1",
    "mapbox-gl": "^3.12.0",
    "next": "15.5.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.65.0",
    "react-map-gl": "^8.0.4",
    "supercluster": "^8.0.1",
    "use-supercluster": "^1.2.0",
    "zod": "^4.1.12",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^4.1.1",
    "@eslint/eslintrc": "^3",
    "@lhci/cli": "^0.15.0",
    "@microsoft/eslint-formatter-sarif": "^3.1.0",
    "@next/bundle-analyzer": "^15.5.5",
    "@playwright/test": "^1.56.0",
    "@storybook/addon-a11y": "^9.1.10",
    "@storybook/addon-docs": "^9.1.10",
    "@storybook/addon-onboarding": "^9.1.10",
    "@storybook/addon-vitest": "^9.1.10",
    "@storybook/nextjs-vite": "^9.1.10",
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/geojson": "^7946.0.16",
    "@types/mapbox-gl": "^3.4.1",
    "@types/node": "^20.19.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/browser": "3.2.4",
    "@vitest/coverage-v8": "3.2.4",
    "@vitest/ui": "^3.2.4",
    "dotenv": "^16.3.1",
    "eslint": "^9",
    "eslint-config-next": "15.3.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-storybook": "^9.1.10",
    "jsdom": "^27.0.0",
    "playwright": "^1.56.0",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "storybook": "^9.1.10",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^3.2.4"
  }
}
