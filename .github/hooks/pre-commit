# Git hooks for security enforcement
# Place in .git/hooks/ and make executable

# Pre-commit hook to prevent sensitive data commits
#!/bin/sh

echo "🔒 Running security pre-commit checks..."

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Function to check for secrets
check_secrets() {
    echo "🔍 Checking for potential secrets..."
    
    # Define secret patterns
    declare -A patterns=(
        ["AWS Access Keys"]="AKIA[0-9A-Z]{16}"
        ["AWS Secret Keys"]="[0-9a-zA-Z/+]{40}"
        ["Google API Keys"]="AIza[0-9A-Za-z\\-_]{35}"
        ["GitHub Personal Access Tokens"]="ghp_[0-9a-zA-Z]{36}"
        ["JWT Tokens"]="eyJ[A-Za-z0-9_-]*\\.[A-Za-z0-9_-]*\\.[A-Za-z0-9_-]*"
        ["Private Keys"]="-----BEGIN [A-Z ]*PRIVATE KEY-----"
        ["Hardcoded Passwords"]="(password|passwd|pwd)\\s*[:=]\\s*[\"'][^\"'\\s]{8,}[\"']"
    )
    
    # Get list of staged files
    staged_files=$(git diff --cached --name-only)
    
    secret_found=false
    
    for file in $staged_files; do
        if [ -f "$file" ]; then
            for pattern_name in "${!patterns[@]}"; do
                pattern="${patterns[$pattern_name]}"
                if git show ":$file" | grep -qE "$pattern"; then
                    echo -e "${RED}❌ Potential secret found in $file: $pattern_name${NC}"
                    secret_found=true
                fi
            done
        fi
    done
    
    if [ "$secret_found" = true ]; then
        echo -e "${RED}❌ Secrets detected! Commit blocked.${NC}"
        echo -e "${YELLOW}💡 Please remove secrets and use environment variables or secret management instead.${NC}"
        return 1
    else
        echo -e "${GREEN}✅ No secrets detected${NC}"
        return 0
    fi
}

# Function to check for sensitive files
check_sensitive_files() {
    echo "🔍 Checking for sensitive files..."
    
    # Define sensitive file patterns
    sensitive_patterns=(
        "*.env"
        "*.pem"
        "*.key"
        "*.p12"
        "*.pfx"
        "*.jks"
        "config/secrets.*"
        "secrets.*"
        "credentials.*"
        "*.sql"
    )
    
    staged_files=$(git diff --cached --name-only)
    sensitive_found=false
    
    for file in $staged_files; do
        for pattern in "${sensitive_patterns[@]}"; do
            if [[ "$file" == $pattern ]]; then
                echo -e "${RED}❌ Sensitive file detected: $file${NC}"
                sensitive_found=true
            fi
        done
    done
    
    if [ "$sensitive_found" = true ]; then
        echo -e "${RED}❌ Sensitive files detected! Commit blocked.${NC}"
        echo -e "${YELLOW}💡 Add sensitive files to .gitignore and use environment variables instead.${NC}"
        return 1
    else
        echo -e "${GREEN}✅ No sensitive files detected${NC}"
        return 0
    fi
}

# Function to check for large files
check_large_files() {
    echo "🔍 Checking for large files..."
    
    max_size=10485760  # 10MB in bytes
    large_found=false
    
    staged_files=$(git diff --cached --name-only)
    
    for file in $staged_files; do
        if [ -f "$file" ]; then
            file_size=$(stat -f%z "$file" 2>/dev/null || stat -c%s "$file" 2>/dev/null)
            if [ "$file_size" -gt "$max_size" ]; then
                echo -e "${RED}❌ Large file detected: $file (${file_size} bytes)${NC}"
                large_found=true
            fi
        fi
    done
    
    if [ "$large_found" = true ]; then
        echo -e "${YELLOW}⚠️ Large files detected. Consider using Git LFS for binary assets.${NC}"
        # Don't block commit for large files, just warn
    else
        echo -e "${GREEN}✅ No large files detected${NC}"
    fi
    
    return 0
}

# Function to check commit message
check_commit_message() {
    echo "🔍 Checking commit message..."
    
    commit_msg_file="$1"
    if [ -z "$commit_msg_file" ]; then
        # Try to get commit message from git
        commit_msg=$(git log -1 --pretty=%B 2>/dev/null || echo "")
    else
        commit_msg=$(cat "$commit_msg_file")
    fi
    
    # Check for required patterns
    if echo "$commit_msg" | grep -qE "^(feat|fix|docs|style|refactor|test|chore|security)(\(.+\))?: .+"; then
        echo -e "${GREEN}✅ Commit message follows conventional format${NC}"
    else
        echo -e "${YELLOW}⚠️ Consider using conventional commit format: type(scope): description${NC}"
        echo -e "${YELLOW}   Examples: feat(auth): add JWT authentication, fix(api): resolve CORS issue${NC}"
    fi
    
    # Check for security-related keywords
    if echo "$commit_msg" | grep -qi "security\|vulnerability\|fix.*cve\|patch.*security"; then
        echo -e "${GREEN}✅ Security-related commit detected${NC}"
    fi
    
    return 0
}

# Run all checks
echo "🚀 Starting pre-commit security checks..."

exit_code=0

check_secrets || exit_code=1
check_sensitive_files || exit_code=1
check_large_files || exit_code=1
check_commit_message || exit_code=1

if [ $exit_code -eq 0 ]; then
    echo -e "${GREEN}✅ All security checks passed! Proceeding with commit.${NC}"
else
    echo -e "${RED}❌ Security checks failed! Commit blocked.${NC}"
    echo -e "${YELLOW}💡 Fix the issues above and try again.${NC}"
fi

exit $exit_code